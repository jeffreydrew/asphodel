// ─── Soul Avatars ─────────────────────────────────────────────────────────────

function randomWanderPoint(floorY) {
  let x, z;
  do {
    x = (Math.random() - 0.5) * 13;  // ±6.5
    z = (Math.random() - 0.5) * 13;
  } while (Math.abs(x) < 2.6 && Math.abs(z) < 2.6);  // avoid spine
  return new THREE.Vector3(x, floorY, z);  // group sits ON the floor surface
}

class SoulAvatar {
  constructor(soul, index) {
    this.id           = soul.id;
    this.name         = soul.name;
    this.index        = index;
    this.color        = SOUL_COLORS[index] ?? 0xffffff;
    this.floorY       = 0;

    // State machine: WANDER | WALKING_TO_TASK | DOING_TASK
    this.state        = 'WANDER';
    this.wanderTarget = randomWanderPoint(0);
    this.wanderTimer  = Math.random() * 4000;
    this.wanderDelay  = 3000 + Math.random() * 5000;
    this.taskTarget   = null;
    this.taskDuration = 0;
    this.taskTimer    = 0;
    this.isMoving     = false;

    this.group = new THREE.Group();
    scene.add(this.group);

    const mat = new THREE.MeshLambertMaterial({
      color:    this.color,
      emissive: new THREE.Color(this.color).multiplyScalar(0.1),
    });

    const LEG_H   = 0.28;
    const TORSO_H = 0.36;
    const HEAD_R  = 0.13;

    const legMat = new THREE.MeshLambertMaterial({
      color: new THREE.Color(this.color).multiplyScalar(0.55),
    });
    this.legL = new THREE.Mesh(new THREE.CylinderGeometry(0.042, 0.038, LEG_H, 6), legMat);
    this.legR = new THREE.Mesh(new THREE.CylinderGeometry(0.042, 0.038, LEG_H, 6), legMat);
    this.legL.position.set(-0.062, LEG_H / 2, 0);
    this.legR.position.set( 0.062, LEG_H / 2, 0);
    this.group.add(this.legL, this.legR);

    this.torso = new THREE.Mesh(new THREE.CylinderGeometry(0.10, 0.13, TORSO_H, 7), mat);
    this.torso.position.y = LEG_H + TORSO_H / 2;
    this.torso.userData.soulId = soul.id;
    this.group.add(this.torso);

    this.head = new THREE.Mesh(new THREE.SphereGeometry(HEAD_R, 8, 7), mat);
    this.head.position.y = LEG_H + TORSO_H + HEAD_R;
    this.head.userData.soulId = soul.id;
    this.group.add(this.head);

    this._torsoY = this.torso.position.y;
    this._headY  = this.head.position.y;

    // Soul-coloured ring (visible when wandering)
    const ringMat = new THREE.MeshBasicMaterial({ color: this.color, transparent: true, opacity: 0.45 });
    this.ring = new THREE.Mesh(new THREE.TorusGeometry(0.20, 0.025, 6, 20), ringMat);
    this.ring.rotation.x = Math.PI / 2;
    this.ring.position.y = 0.01;
    this.group.add(this.ring);

    // Green pulsing task ring (visible only when DOING_TASK)
    const taskRingMat = new THREE.MeshBasicMaterial({ color: 0x00ff88, transparent: true, opacity: 0 });
    this.taskRing = new THREE.Mesh(new THREE.TorusGeometry(0.28, 0.035, 6, 24), taskRingMat);
    this.taskRing.rotation.x = Math.PI / 2;
    this.taskRing.position.y = 0.01;
    this.taskRing.visible = false;
    this.group.add(this.taskRing);

    // Name label
    const labelDiv = document.createElement('div');
    labelDiv.className   = 'soul-label';
    labelDiv.textContent = soul.name.split(' ')[0];
    labelDiv.id          = `lbl-${soul.id}`;
    this.label = new CSS2DObject(labelDiv);
    this.label.position.y = LEG_H + TORSO_H + HEAD_R * 2 + 0.10;
    this.group.add(this.label);

    this.body = this.torso;
    this.group.position.copy(this.wanderTarget);
  }

  setFloor(action) {
    const hour = new Date().getHours();
    const isWorkHours = hour >= 9 && hour < 17;

    // Determine target floor (9–17: everyone in OFFICE)
    const targetFloor = isWorkHours
      ? FLOORS.find(f => f.label === 'OFFICE')
      : (FLOORS.find(f => f.actions.includes(action)) ?? FLOORS[0]);

    const newFloorY = targetFloor.y;

    // Floor changed — snap Y and reset to WANDER
    if (Math.abs(newFloorY - this.floorY) > 0.1) {
      this.floorY = newFloorY;
      this.group.position.y = newFloorY;
      this.state = 'WANDER';
      this.wanderTarget = randomWanderPoint(newFloorY);
      this.taskRing.visible = false;
      this.ring.visible     = true;
    }

    // Only assign a new task if currently wandering (never interrupt an active task)
    if (this.state !== 'WANDER') return;

    const label = targetFloor.label;
    let xz  = null;
    let dur = TASK_MS.default;

    if (isWorkHours && label === 'OFFICE') {
      xz  = OFFICE_DESK_XZ[this.index] ?? OFFICE_DESK_XZ[0];
      dur = TASK_MS.office;
    } else if (label === 'GYM') {
      xz  = GYM_SPOT_XZ[this.index % GYM_SPOT_XZ.length];
      dur = TASK_MS.gym;
    } else if (label === 'BEDROOM') {
      xz  = BED_XZ[this.index % BED_XZ.length];
      dur = TASK_MS.bedroom;
    } else if (label === 'KITCHEN') {
      xz  = KITCHEN_SPOT_XZ[this.index % KITCHEN_SPOT_XZ.length];
      dur = TASK_MS.kitchen;
    }
    // LOBBY / LIBRARY: free wander, no committed task

    if (xz) {
      this.taskTarget   = new THREE.Vector3(xz[0], this.floorY, xz[1]);
      this.taskDuration = dur;
      this.taskTimer    = 0;
      this.state        = 'WALKING_TO_TASK';
    }
  }

  update(delta, ts) {
    const WALK_SPEED = 1.8; // units/second

    if (this.state === 'WANDER') {
      const to   = new THREE.Vector3().subVectors(this.wanderTarget, this.group.position);
      to.y       = 0;
      const dist = to.length();

      if (dist < 0.15) {
        this.isMoving    = false;
        this.wanderTimer += delta * 1000;
        if (this.wanderTimer >= this.wanderDelay) {
          this.wanderTarget = randomWanderPoint(this.floorY);
          this.wanderTimer  = 0;
          this.wanderDelay  = 3000 + Math.random() * 5000;
        }
      } else {
        this.isMoving = true;
        this.group.position.addScaledVector(to.normalize(), Math.min(WALK_SPEED * delta, dist));
      }
      this.group.position.y = this.floorY;

    } else if (this.state === 'WALKING_TO_TASK') {
      const to   = new THREE.Vector3().subVectors(this.taskTarget, this.group.position);
      to.y       = 0;
      const dist = to.length();

      if (dist < 0.15) {
        this.group.position.set(this.taskTarget.x, this.floorY, this.taskTarget.z);
        this.state         = 'DOING_TASK';
        this.taskTimer     = 0;
        this.isMoving      = false;
        this.taskRing.visible = true;
        this.ring.visible     = false;
      } else {
        this.isMoving = true;
        this.group.position.addScaledVector(to.normalize(), Math.min(WALK_SPEED * delta, dist));
        this.group.position.y = this.floorY;
      }

    } else if (this.state === 'DOING_TASK') {
      this.isMoving   = false;
      this.taskTimer += delta * 1000;

      // Pulse the green ring
      this.taskRing.material.opacity = 0.25 + 0.55 * (0.5 + 0.5 * Math.sin(ts * 0.004));

      if (this.taskTimer >= this.taskDuration) {
        this.state            = 'WANDER';
        this.taskRing.visible = false;
        this.ring.visible     = true;
        this.wanderTarget     = randomWanderPoint(this.floorY);
        this.wanderTimer      = 0;
        this.wanderDelay      = 8000 + Math.random() * 10000; // longer free wander after task
      }
    }

    // Face direction of travel
    if (this.isMoving) {
      const tgt = (this.state === 'WALKING_TO_TASK') ? this.taskTarget : this.wanderTarget;
      const dx  = tgt.x - this.group.position.x;
      const dz  = tgt.z - this.group.position.z;
      this.group.rotation.y += (Math.atan2(dx, dz) - this.group.rotation.y) * 0.10;
    }

    // Procedural body animation
    if (this.isMoving) {
      const walk = ts * 0.006;
      this.torso.position.y = this._torsoY + Math.abs(Math.sin(walk)) * 0.022;
      this.head.position.y  = this._headY  + Math.abs(Math.sin(walk)) * 0.022;
      this.legL.rotation.x  =  Math.sin(walk) * 0.55;
      this.legR.rotation.x  = -Math.sin(walk) * 0.55;
      this.group.rotation.x = 0.05;
    } else {
      const breathe = Math.sin(ts * 0.0014 + this.index * 1.5) * 0.007;
      this.torso.position.y = this._torsoY + breathe;
      this.head.position.y  = this._headY  + breathe;
      this.legL.rotation.x  = 0;
      this.legR.rotation.x  = 0;
      this.group.rotation.x = 0;
    }
  }

  setSelected(selected) {
    const div = document.getElementById(`lbl-${this.id}`);
    if (div) div.className = `soul-label${selected ? ' selected' : ''}`;
    if (this.torso?.material?.emissive) {
      this.torso.material.emissive.setScalar(selected ? 0.3 : 0.1);
      this.head.material.emissive.setScalar(selected ? 0.3 : 0.1);
    }
  }

  pulse() {
    const orig = this.torso?.material?.color?.clone();
    if (!orig) return;
    this.torso.material.color.set(0xffffff);
    this.head.material.color.set(0xffffff);
    setTimeout(() => {
      this.torso?.material?.color?.copy(orig);
      this.head?.material?.color?.copy(orig);
    }, 300);
  }
}

// ─── World Update Handler ─────────────────────────────────────────────────────

let prevLogIds = new Set();

function handleUpdate(data) {
  worldData = data;

  data.souls.forEach((soul, i) => {
    if (!avatars[i]) avatars[i] = new SoulAvatar(soul, i);
    avatars[i].setFloor(soul.last_action ?? 'idle');

    const hasSig = data.recent_log.some(e =>
      e.soul_id === soul.id && e.significance === 'SIGNIFICANT' && !prevLogIds.has(e.id),
    );
    if (hasSig) avatars[i].pulse();
  });

  data.recent_log.forEach(e => prevLogIds.add(e.id));
  if (prevLogIds.size > 200) prevLogIds = new Set([...prevLogIds].slice(-100));

  populateSoulSelect(data.souls);
  updateHUD(data);
}

// ─── Interaction ──────────────────────────────────────────────────────────────

function onClick(event) {
  mouse.set(
    (event.clientX / window.innerWidth)  * 2 - 1,
    -(event.clientY / window.innerHeight) * 2 + 1,
  );
  raycaster.setFromCamera(mouse, camera);

  // Hit-test torso + head of each avatar
  const meshes = avatars.filter(Boolean).flatMap(a => [a.torso, a.head].filter(Boolean));

  const hits = raycaster.intersectObjects(meshes);
  if (hits.length > 0) {
    let obj = hits[0].object;
    let soulId = null;
    while (obj && !soulId) {
      soulId = obj.userData.soulId;
      obj = obj.parent;
    }
    if (soulId) {
      selectedId = soulId;
      avatars.forEach(a => a?.setSelected(a.id === soulId));
      openSoulPanel(soulId);
    }
  }
}

// ─── Animation Loop ───────────────────────────────────────────────────────────

let lastTime = 0;

function animate(ts = 0) {
  requestAnimationFrame(animate);
  const delta = Math.min((ts - lastTime) / 1000, 0.1);
  lastTime = ts;

  controls.update();
  avatars.forEach(a => a?.update(delta, ts));

  scene.traverse(obj => {
    if (obj.userData.isBlink) {
      obj.material.opacity = 0.3 + 0.7 * (0.5 + 0.5 * Math.sin(ts * 0.003));
      obj.material.transparent = true;
    }
  });

  renderer.render(scene, camera);
  labelRenderer.render(scene, camera);
}

function onResize() {
  const aspect = window.innerWidth / window.innerHeight;
  const d      = Math.abs(camera.top);
  camera.left  = -d * aspect;
  camera.right =  d * aspect;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
  labelRenderer.setSize(window.innerWidth, window.innerHeight);
  controls.update();
}
